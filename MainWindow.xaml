<Window x:Class="Ion.Tool.Rename.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Ion.Tool.Rename"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="Rename" 
    Height="720" 
    Width="900"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Geometry x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type ComboBox}, ResourceId=StandardArrowGeometry}">
            M 0 0
        </Geometry>
        
        <Style TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="local:XComboBox.HideArrow" Value="True"/>
            <Setter Property="Padding" Value="6,5"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFF"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="AlternatingRowBackground" Value="#0A000000"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Padding="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="BorderBrush" Value="#11000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8,7,8,8"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabControl">
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Padding" Value="7,4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12px"/>
        </Style>

        <Style x:Key="GroupTitlePanel" TargetType="DockPanel">
            <Setter Property="Margin" Value="5,0"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0088EE"/>
        </Style>
        <Style x:Key="GroupTitleIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="Foreground" Value="#0088EE"/>
        </Style>
        <Style x:Key="LabelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
    </Window.Resources>
    <Grid AllowDrop="True" Background="#01FFFFFF" DragOver="Window_DragEnter">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>
            <Border       
                Background="#07000000"
                BorderBrush="#22000000"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TabControl Margin="10,10,10,0" Padding="10,8,10,10">
                        <TabItem>
                            <TabItem.Header>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf07b;</TextBlock>
                                    <TextBlock Style="{StaticResource Title}">FOLDER</TextBlock>
                                </DockPanel>
                            </TabItem.Header>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding FolderPreview}"
                                        Height="28" Width="28"
                                        Margin="0,0,5,0" 
                                        Stretch="UniformToFill"
                                        Visibility="{Binding FolderPreview, Converter={StaticResource ToVisibilityConverter}}"/>
                                    <TextBox Grid.Column="1" x:Name="FolderElement" local:Preset.Id="Folder"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Center"
                                        Tag="0">
                                        <Binding Path="Folder" UpdateSourceTrigger="LostFocus">
                                            <Binding.ValidationRules>
                                                <local:RuleFolder ValidatesOnTargetUpdated="True"/>
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox>
                                    <Button Grid.Column="2" Content="Browse..." Click="OnBrowse" Margin="10,0,0,0" Style="{StaticResource BlueButton}"/>
                                </Grid>

                                <CheckBox Content="Include subfolders" 
                                    IsChecked="{Binding FolderSub, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                    Margin="0,10,0,0" 
                                    Checked="OnUpdated" 
                                    Unchecked="OnUpdated"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                    <TabControl Grid.Row="1" Margin="10">
                        <TabItem>
                            <TabItem.Header>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf15b;</TextBlock>
                                    <TextBlock Style="{StaticResource Title}">File</TextBlock>
                                </DockPanel>
                            </TabItem.Header>
                            <ScrollViewer 
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                HorizontalScrollBarVisibility="Disabled" 
                                Padding="10,8,10,10"
                                VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <GroupBox>
                                        <GroupBox.Header>
                                            <DockPanel Style="{StaticResource GroupTitlePanel}">
                                                <TextBlock Style="{StaticResource GroupTitle}">NAME</TextBlock>
                                            </DockPanel>
                                        </GroupBox.Header>
                                        <Grid Margin="0,0,0,-5">
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Label Grid.Row="0">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource LabelTitle}">
                                                        <Run>Format</Run> <Run FontStyle="Italic" Foreground="#55000000">{n} = number</Run>
                                                    </TextBlock>
                                                    <TextBox x:Name="FileNameFormatElement" local:Preset.Id="FileNameFormat">
                                                        <Binding Path="FileNameFormat" UpdateSourceTrigger="LostFocus">
                                                            <Binding.ValidationRules>
                                                                <local:RuleFileNameFormat ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="1">
                                                <StackPanel>
                                                    <TextBlock Text="Increment at" Style="{StaticResource LabelTitle}"/>
                                                    <TextBox Tag="0" x:Name="FileNameIncrementAtElement" TextChanged="OnUpdated">
                                                        <Binding Path="FileNameIncrementAt" UpdateSourceTrigger="LostFocus">
                                                            <Binding.ValidationRules>
                                                                <local:RuleInt32 ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="2">
                                                <StackPanel>
                                                    <TextBlock Text="Increment by" Style="{StaticResource LabelTitle}"/>
                                                    <TextBox Tag="0" x:Name="FileNameIncrementByElement" TextChanged="OnUpdated">
                                                        <Binding Path="FileNameIncrementBy" UpdateSourceTrigger="LostFocus">
                                                            <Binding.ValidationRules>
                                                                <local:RuleInt32 ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="3">
                                                <CheckBox Content="Increment by extension" 
                                                    IsChecked="{Binding FileNameIncrementByExtension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Checked="OnUpdated" Unchecked="OnUpdated"/>
                                            </Label>
                                            <Label Grid.Row="4">
                                                <StackPanel>
                                                    <TextBlock Text="Number" Style="{StaticResource LabelTitle}"/>
                                                    <ComboBox SelectedIndex="{Binding FileNameNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        SelectionChanged="OnUpdated">
                                                        <ComboBoxItem Content="Binary"/>
                                                        <ComboBoxItem Content="Decimal"/>
                                                        <ComboBoxItem Content="Hexadecimal"/>
                                                        <ComboBoxItem Content="Letter (Lower)"/>
                                                        <ComboBoxItem Content="Letter (Upper)"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="5">
                                                <StackPanel>
                                                    <TextBlock Text="Number padding" Style="{StaticResource LabelTitle}"/>
                                                    <Slider Minimum="1" Maximum="10" Value="{Binding FileNameNumberPadding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnUpdated"/>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="6">
                                                <StackPanel>
                                                    <TextBlock Text="Number padding character" Style="{StaticResource LabelTitle}"/>
                                                    <TextBox x:Name="FileNameNumberPaddingCharacterElement" 
                                                        local:Preset.Id="FileNameNumberPaddingCharacter"
                                                        MaxLength="1" 
                                                        Tag="0"  
                                                        TextChanged="OnUpdated">
                                                        <Binding Path="FileNameNumberPaddingCharacter" UpdateSourceTrigger="LostFocus">
                                                            <Binding.ValidationRules>
                                                                <local:RuleMinimum Minimum="1" ValidatesOnTargetUpdated="True"/>
                                                                <local:RuleFileName ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>
                                        </Grid>
                                    </GroupBox>
                                    <GroupBox>
                                        <GroupBox.Header>
                                            <DockPanel Style="{StaticResource GroupTitlePanel}">
                                                <TextBlock Style="{StaticResource GroupTitle}">EXTENSION</TextBlock>
                                            </DockPanel>
                                        </GroupBox.Header>
                                        <StackPanel>
                                            <Label>
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,5">
                                                        <CheckBox Content="Override" 
                                                            Checked="OnUpdate" Unchecked="OnUpdate" 
                                                            IsChecked="{Binding FileExtensionOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DockPanel>
                                                    <TextBox x:Name="FileExtensionOverrideElement" 
                                                        local:Preset.Id="FileExtensionOverride"
                                                        IsEnabled="{Binding FileExtensionOverride}" 
                                                        Tag="0" 
                                                        TextChanged="OnUpdated">
                                                        <Binding Path="FileExtensionOverrideNew" UpdateSourceTrigger="LostFocus">
                                                            <Binding.ValidationRules>
                                                                <local:RuleFileName ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>

                                            <Label>
                                                <StackPanel>
                                                    <TextBlock Text="Casing" Style="{StaticResource LabelTitle}"/>
                                                    <ComboBox SelectedIndex="{Binding FileExtensionCasing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        SelectionChanged="OnUpdated">
                                                        <ComboBoxItem Content="Original"/>
                                                        <ComboBoxItem Content="lowercase"/>
                                                        <ComboBoxItem Content="UPPERCASE"/>
                                                        <ComboBoxItem Content="Capitalized"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Label>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf0b0;</TextBlock>
                                    <TextBlock Style="{StaticResource Title}">Filter</TextBlock>
                                    <Border Background="#0088EE" CornerRadius="3" Margin="5,0,0,0" Padding="5,3">
                                        <TextBlock FontSize="10" FontWeight="Bold" Foreground="#FFF" Text="{Binding Filters.Count}"/>
                                    </Border>
                                </DockPanel>
                            </TabItem.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <ListBox x:Name="FilterListBox" ItemsSource="{Binding Filters}" 
                                    BorderThickness="1" 
                                    Background="Transparent"
                                    HorizontalContentAlignment="Stretch" 
                                    Margin="10"
                                    Padding="1"
                                    SelectionMode="Extended" >
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <ComboBox ItemsSource="{Binding AllAttributes}" 
                                                        SelectedItem="{Binding TargetAttribute, UpdateSourceTrigger=PropertyChanged}" 
                                                        Grid.Column="0"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center"/>

                                                    <ComboBox Grid.Column="1" x:Name="ModeCombo"
                                                        Margin="0,0,5,0"
                                                        VerticalAlignment="Center">
                                                        <ComboBox.Style>
                                                            <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
                                                                <Setter Property="ItemsSource" Value="{Binding StringModes}"/>
                                                                <Setter Property="SelectedItem" Value="{Binding SelectedMode, UpdateSourceTrigger=PropertyChanged}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CurrentType}" Value="Numeric">
                                                                        <Setter Property="ItemsSource" Value="{Binding NumericModes}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CurrentType}" Value="DateTime">
                                                                        <Setter Property="ItemsSource" Value="{Binding DateModes}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CurrentType}" Value="Boolean">
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </ComboBox.Style>
                                                    </ComboBox>

                                                    <Grid Grid.Column="2"
                                                        Margin="0,0,5,0">
                                                        <TextBox
                                                            VerticalContentAlignment="Center"
                                                            Visibility="{Binding CurrentType, ConverterParameter=String, Converter={StaticResource FilterTypeToVisibilityConverter}}">
                                                            <Binding Path="StringValue" UpdateSourceTrigger="LostFocus">
                                                                <Binding.ValidationRules>
                                                                    <local:RuleRequire ValidatesOnTargetUpdated="True"/>
                                                                </Binding.ValidationRules>
                                                            </Binding>
                                                        </TextBox>

                                                        <TextBox
                                                            VerticalContentAlignment="Center"
                                                            Visibility="{Binding CurrentType, ConverterParameter=Numeric, Converter={StaticResource FilterTypeToVisibilityConverter}}">
                                                            <TextBox.Text>
                                                                <Binding Path="LongValue" UpdateSourceTrigger="LostFocus">
                                                                    <Binding.ValidationRules>
                                                                        <local:RuleRequire ValidatesOnTargetUpdated="True"/>
                                                                        <local:RuleInt64 ValidatesOnTargetUpdated="True"/>
                                                                    </Binding.ValidationRules>
                                                                </Binding>
                                                            </TextBox.Text>
                                                        </TextBox>

                                                        <DatePicker SelectedDate="{Binding DateValue, UpdateSourceTrigger=PropertyChanged}" 
                                                            Visibility="{Binding CurrentType, ConverterParameter=DateTime, Converter={StaticResource FilterTypeToVisibilityConverter}}"/>

                                                        <CheckBox IsChecked="{Binding BoolValue, UpdateSourceTrigger=PropertyChanged}" 
                                                            VerticalAlignment="Center"
                                                            Visibility="{Binding CurrentType, ConverterParameter=Boolean, Converter={StaticResource FilterTypeToVisibilityConverter}}"/>
                                                    </Grid>

                                                    <Button Grid.Column="3"
                                                        Click="OnFilterRemoved"  
                                                        Padding="10,5"
                                                        Style="{StaticResource RedButton}">
                                                        <TextBlock Style="{StaticResource Icon}" Foreground="#FFF" VerticalAlignment="Center">&#xf1f8;</TextBlock>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <Border Grid.Row="1" Margin="-2" Style="{DynamicResource Footer}">
                                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                                        <Button
                                            Click="OnFilterAdd" 
                                            Margin="0,0,5,0"
                                            Style="{StaticResource BlueButton}">
                                            <DockPanel>
                                                <TextBlock Style="{StaticResource Icon}" Foreground="#FFF" VerticalAlignment="Center">&#xf067;</TextBlock>
                                                <TextBlock Margin="5,0,0,0">Add</TextBlock>
                                            </DockPanel>
                                        </Button>
                                        <Button
                                            Click="OnFilterRemovedSelected" 
                                            Margin="0,0,5,0"
                                            Style="{StaticResource RedButton}">
                                            <DockPanel>
                                                <TextBlock Style="{StaticResource Icon}" Foreground="#FFF" VerticalAlignment="Center">&#xf068;</TextBlock>
                                                <TextBlock Margin="5,0,0,0">Remove</TextBlock>
                                            </DockPanel>
                                        </Button>
                                        <Button
                                            Click="OnFiltersCleared"
                                            Style="{StaticResource RedButton}">
                                            <DockPanel>
                                                <TextBlock Style="{StaticResource Icon}" Foreground="#FFF" VerticalAlignment="Center">&#xf1f8;</TextBlock>
                                                <TextBlock Margin="5,0,0,0">Clear</TextBlock>
                                            </DockPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>                        
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf013;</TextBlock>
                                    <TextBlock Style="{StaticResource Title}">Options</TextBlock>
                                </DockPanel>
                            </TabItem.Header>
                            <StackPanel Margin="10,8,10,10">
                                <GroupBox>
                                    <GroupBox.Header>
                                        <DockPanel Style="{StaticResource GroupTitlePanel}">
                                            <TextBlock Style="{StaticResource GroupTitleIcon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf017;</TextBlock>
                                            <TextBlock Style="{StaticResource GroupTitle}">DELAY</TextBlock>
                                        </DockPanel>
                                    </GroupBox.Header>
                                    <StackPanel>
                                        <Label>
                                            <StackPanel>
                                                <TextBlock Text="Renaming" Style="{StaticResource LabelTitle}"/>
                                                <TextBox x:Name="DelayRenameElement" Tag="0" local:Preset.Id="DelayRename">
                                                    <Binding Path="DelayRename" UpdateSourceTrigger="LostFocus">
                                                        <Binding.ValidationRules>
                                                            <local:RuleInt32 ValidatesOnTargetUpdated="True"/>
                                                            <local:RuleInt32Negative ValidatesOnTargetUpdated="True"/>
                                                            <local:RuleRequire ValidatesOnTargetUpdated="True"/>
                                                        </Binding.ValidationRules>
                                                    </Binding>
                                                </TextBox>
                                            </StackPanel>
                                        </Label>
                                        <Label>
                                            <StackPanel>
                                                <TextBlock Text="Updating" Style="{StaticResource LabelTitle}"/>
                                                <TextBox x:Name="DelayUpdateElement" Tag="0" local:Preset.Id="DelayUpdate" TextChanged="OnUpdate">
                                                    <Binding Path="DelayUpdate" UpdateSourceTrigger="LostFocus">
                                                        <Binding.ValidationRules>
                                                            <local:RuleInt32 ValidatesOnTargetUpdated="True"/>
                                                            <local:RuleInt32Negative ValidatesOnTargetUpdated="True"/>
                                                            <local:RuleRequire ValidatesOnTargetUpdated="True"/>
                                                        </Binding.ValidationRules>
                                                    </Binding>
                                                </TextBox>
                                            </StackPanel>
                                        </Label>
                                    </StackPanel>
                                </GroupBox>
                                <GroupBox>
                                    <GroupBox.Header>
                                        <DockPanel Style="{StaticResource GroupTitlePanel}">
                                            <TextBlock Style="{StaticResource GroupTitleIcon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf188;</TextBlock>
                                            <TextBlock Style="{StaticResource GroupTitle}">LOG</TextBlock>
                                        </DockPanel>
                                    </GroupBox.Header>
                                    <StackPanel>
                                        <CheckBox Content="Enable" IsChecked="{Binding LogEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Checked="OnUpdate" Unchecked="OnUpdate"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf074;</TextBlock>
                                    <TextBlock Style="{StaticResource Title}">Test</TextBlock>
                                </DockPanel>
                            </TabItem.Header>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <ScrollViewer Padding="10,8,10,10">
                                    <StackPanel>
                                        <GroupBox>
                                            <GroupBox.Header>
                                                <DockPanel Style="{StaticResource GroupTitlePanel}">
                                                    <TextBlock Style="{StaticResource GroupTitleIcon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf07b;</TextBlock>
                                                    <TextBlock Style="{StaticResource GroupTitle}">FOLDER</TextBlock>
                                                </DockPanel>
                                            </GroupBox.Header>
                                            <StackPanel>
                                                <Label>
                                                    <StackPanel>
                                                        <TextBlock Text="Parent" Style="{StaticResource LabelTitle}"/>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <TextBox Text="{Binding TestTargetRoot, UpdateSourceTrigger=PropertyChanged}" local:Preset.Id="TestTargetRoot"/>
                                                            <Button Grid.Column="1" Content="Browse..." Click="OnBrowseTestRoot" Margin="5,0,0,0" Style="{StaticResource BlueButton}"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </Label>

                                                <Label>
                                                    <StackPanel>
                                                        <TextBlock Text="Name" Style="{StaticResource LabelTitle}"/>
                                                        <TextBox Text="{Binding TestFolderName, UpdateSourceTrigger=PropertyChanged}" local:Preset.Id="TestFolderName"/>
                                                    </StackPanel>
                                                </Label>

                                                <CheckBox Content="Open after creating" 
                                                    IsChecked="{Binding TestAutoSelect, Mode=TwoWay}"/>
                                            </StackPanel>
                                        </GroupBox>
                                        <GroupBox>
                                            <GroupBox.Header>
                                                <DockPanel Style="{StaticResource GroupTitlePanel}">
                                                    <TextBlock Style="{StaticResource GroupTitleIcon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf15b;</TextBlock>
                                                    <TextBlock Style="{StaticResource GroupTitle}">FILE</TextBlock>
                                                </DockPanel>
                                            </GroupBox.Header>
                                            <StackPanel>
                                                <Label>
                                                    <StackPanel>
                                                        <TextBlock Text="Count" Style="{StaticResource LabelTitle}"/>
                                                        <TextBox Text="{Binding TestFileCount, UpdateSourceTrigger=PropertyChanged}" local:Preset.Id="TestFileCount"/>
                                                    </StackPanel>
                                                </Label>
                                                <Label>
                                                    <StackPanel>
                                                        <TextBlock Text="Extension" Style="{StaticResource LabelTitle}"/>
                                                        <TextBox Text="{Binding TestFileExtension, UpdateSourceTrigger=PropertyChanged}" local:Preset.Id="TestFileExtension"/>
                                                    </StackPanel>
                                                </Label>

                                                <Label Margin="0">
                                                    <StackPanel>
                                                        <TextBlock Text="Name length" Style="{StaticResource LabelTitle}"/>
                                                        <TextBox Text="{Binding TestNameLength, UpdateSourceTrigger=PropertyChanged}" local:Preset.Id="TestNameLength"/>
                                                    </StackPanel>
                                                </Label>
                                            </StackPanel>
                                        </GroupBox>
                                    </StackPanel>
                                </ScrollViewer>
                                <Border Grid.Row="2" Margin="-2" Style="{DynamicResource Footer}">
                                    <Button
                                        Click="OnTest" 
                                        Style="{StaticResource GreenButton}"
                                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}">
                                        <DockPanel HorizontalAlignment="Center">
                                            <TextBlock Style="{StaticResource Icon}" Foreground="#FFF" VerticalAlignment="Center">&#xf074;</TextBlock>
                                            <TextBlock Margin="5,0,0,0">Create</TextBlock>
                                        </DockPanel>
                                    </Button>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="1" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" Background="Transparent" ShowsPreview="True" Width="10"/>
            <TabControl Grid.Column="2"
                Margin="0,10,10,10">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf15b;</TextBlock>
                            <TextBlock Style="{StaticResource Title}" VerticalAlignment="Center">Files</TextBlock>
                            <Border Background="#0088EE" CornerRadius="3" Margin="5,0" Padding="5,3">
                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="#FFF" Text="{Binding Files.Count}"/>
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="-2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid
                            AutoGenerateColumns="False"
                            BorderThickness="0"
                            HeadersVisibility="Column"
                            ItemsSource="{Binding Files}"
                            SelectionMode="Single"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            CanUserResizeRows="False"
                            CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding OldPath, Converter={StaticResource ThumbnailConverter}}"
                                                Height="20" Width="20"
                                                Stretch="UniformToFill"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Old" Width="*" SortMemberPath="OldPath">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OldName}" ToolTip="{Binding OldPath}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="New" Width="*" SortMemberPath="NewPath">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                        <TextBlock Text="{Binding NewName}" ToolTip="{Binding NewPath}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Status" Width="Auto" SortMemberPath="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="8" Height="8" Fill="{Binding Status}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Folder" Binding="{Binding RelativeFolder}" Visibility="Collapsed"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="1" 
                            Background="#07000000" 
                            BorderBrush="#22000000" 
                            BorderThickness="1"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" 
                            Margin="-3" 
                            Padding="5">
                            <DockPanel HorizontalAlignment="Right">
                                <CheckBox x:Name="AutoUpdateElement" Content="Auto update" 
                                    Checked="OnUpdate" Unchecked="OnUpdate" 
                                    IsChecked="True" 
                                    Margin="0,0,10,0" 
                                    VerticalAlignment="Center"/>
                                <Button Click="OnUpdate" IsEnabled="{Binding IsChecked, Converter={StaticResource InverseBooleanConverter}, ElementName=AutoUpdateElement}" Style="{StaticResource BlueButton}">
                                    <DockPanel>
                                        <TextBlock Text="&#xf021;"                            
                                            Foreground="#FFF"
                                            Margin="0,0,5,0" 
                                            RenderTransformOrigin="0.5,0.5"
                                            VerticalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="0"/>
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Icon}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="RotateAction">
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                            From="0"
                                                                            To="360"
                                                                            RepeatBehavior="Forever"
                                                                            Duration="0:0:2"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="RotateAction"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock>Update</TextBlock>
                                    </DockPanel>
                                </Button>
                            </DockPanel>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FolderElement}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameFormatElement}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameIncrementByElement}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameIncrementAtElement}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf017;</TextBlock>
                            <TextBlock Style="{StaticResource Title}" VerticalAlignment="Center">History</TextBlock>
                            <Border Background="#0088EE" CornerRadius="3" Margin="5,0,0,0" Padding="5,3">
                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="#FFF" Text="{Binding UndoActions.Count}"/>
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="-2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid
                            AutoGenerateColumns="False"
                            BorderThickness="0"
                            HeadersVisibility="Column"
                            ItemsSource="{Binding UndoActions}"
                            SelectionMode="Single"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            CanUserResizeRows="False"
                            CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding Folder, Converter={StaticResource ThumbnailConverter}}"
                                                Height="20" Width="20"
                                                Stretch="UniformToFill"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Folder" Width="*" SortMemberPath="Folder">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Folder}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Folder}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Time" Width="*" SortMemberPath="Time">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Time}" TextTrimming="CharacterEllipsis" ToolTip="{Binding Time}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="1" 
                            Background="#07000000" 
                            BorderBrush="#22000000" 
                            BorderThickness="1"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" 
                            Margin="-3" 
                            Padding="5">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <DockPanel HorizontalAlignment="Right">
                                <Button Click="OnRedo" IsEnabled="{Binding RedoActions.Count, Converter={StaticResource NotZeroConverter}}" Margin="0,0,5,0" Style="{StaticResource BlueButton}">
                                    <DockPanel>
                                        <TextBlock Text="&#xf01e;"                            
                                            Foreground="#FFF"
                                            Margin="0,0,5,0" 
                                            RenderTransformOrigin="0.5,0.5"
                                            Style="{StaticResource Icon}"
                                            VerticalAlignment="Center"/>
                                        <TextBlock>Redo</TextBlock>
                                    </DockPanel>
                                </Button>
                                <Button Click="OnUndo" IsEnabled="{Binding UndoActions.Count, Converter={StaticResource NotZeroConverter}}" Margin="0,0,5,0" Style="{StaticResource BlueButton}">
                                    <DockPanel>
                                        <TextBlock Text="&#xf0e2;"                            
                                            Foreground="#FFF"
                                            Margin="0,0,5,0" 
                                            RenderTransformOrigin="0.5,0.5"
                                            Style="{StaticResource Icon}"
                                            VerticalAlignment="Center"/>
                                        <TextBlock>Undo</TextBlock>
                                    </DockPanel>
                                </Button>
                                <Button Click="OnClearHistory">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource RedButton}">
                                            <Setter Property="IsEnabled" Value="False"/>
                                            <Style.Triggers>
                                                <MultiDataTrigger>
                                                    <MultiDataTrigger.Conditions>
                                                        <Condition Binding="{Binding RedoActions.Count, Converter={StaticResource NotZeroConverter}}" Value="True"/>
                                                        <Condition Binding="{Binding UndoActions.Count, Converter={StaticResource NotZeroConverter}}" Value="True"/>
                                                    </MultiDataTrigger.Conditions>
                                                    <Setter Property="IsEnabled" Value="True"/>
                                                </MultiDataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <DockPanel>
                                        <TextBlock Text="&#xf1f8;"                            
                                            Foreground="#FFF"
                                            Margin="0,0,5,0" 
                                            Style="{StaticResource Icon}"
                                            VerticalAlignment="Center"/>
                                        <TextBlock>Clear</TextBlock>
                                    </DockPanel>
                                </Button>
                            </DockPanel>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf188;</TextBlock>
                            <TextBlock Style="{StaticResource Title}" VerticalAlignment="Center">Log</TextBlock>
                            <Border Background="#0088EE" CornerRadius="3" Margin="5,0,0,0" Padding="5,3">
                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="#FFF" Text="{Binding Log.Count}"/>
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <DataGrid
                        AutoGenerateColumns="False"
                        BorderThickness="0"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="False"
                        CanUserResizeColumns="True"
                        CanUserResizeRows="False"
                        CanUserSortColumns="True"
                        HeadersVisibility="Column"
                        ItemsSource="{Binding Log}" 
                        Margin="-2"
                        SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Message" Width="6*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Error.Message}" 
                                            TextTrimming="CharacterEllipsis"
                                            ToolTip="{Binding Error.Message}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Time" Width="4*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Time}"
                                            TextTrimming="CharacterEllipsis"
                                            ToolTip="{Binding Time}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>
        <ProgressBar Grid.Row="1" 
            BorderBrush="#33000000"
            BorderThickness="0,1,0,0"
            Height="8" 
            IsIndeterminate="True"
            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Border Grid.Row="2" Style="{DynamicResource Footer}">
            <Button Click="OnRenamed">
                <Button.Content>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="&#xf021;"
                            Foreground="#FFF"
                            Margin="0,0,5,0" 
                            RenderTransformOrigin="0.5,0.5" 
                            VerticalAlignment="Center">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Icon}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RotateAction">
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                            From="0"
                                                            To="360"
                                                            RepeatBehavior="Forever"
                                                            Duration="0:0:3"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RotateAction"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Rename" VerticalAlignment="Center"/>
                        <Border Background="#33000000" Margin="5,0" Padding="5,2">
                            <TextBlock FontStyle="Italic" Text="{Binding FileCountText}" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Button.Content>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource GreenButton}">
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Files.Count}" Value="0">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=DelayRenameElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=DelayUpdateElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FolderElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileExtensionOverrideElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameFormatElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameIncrementByElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameIncrementAtElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameNumberPaddingCharacterElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style> 
                </Button.Style>
            </Button>
        </Border>

        <Grid Grid.RowSpan="3" x:Name="DragDropOverlay" 
            AllowDrop="True"
            Background="#CCFFFFFF" 
            DragLeave="DragDropOverlay_DragLeave"
            Drop="DragDropOverlay_Drop"
            Visibility="{Binding IsDraggingOver, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Image Source="{Binding IsDraggingOverFolder, Converter={StaticResource ThumbnailConverter}}"
                    Height="128" Width="128"
                    HorizontalAlignment="Center" 
                    Margin="0,0,0,10"
                    Stretch="UniformToFill"
                    Visibility="{Binding IsDraggingOverFolder, Converter={StaticResource ToVisibilityConverter}}"/>
                <TextBlock Text="{Binding IsDraggingOverFolder}" 
                    FontSize="24" 
                    FontWeight="Bold" 
                    Foreground="#333"
                    Margin="64,0"
                    TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>