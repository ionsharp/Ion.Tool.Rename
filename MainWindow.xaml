<Window x:Class="Ion.Tool.Rename.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Ion.Tool.Rename"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    Title="Rename" 
    Height="720" 
    Width="800"
    WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <local:ThumbnailConverter x:Key="ThumbnailConverter" />
        <local:ToVisibilityConverter x:Key="ToVisibilityConverter" />
        
        <ControlTemplate x:Key="ErrorTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="TextBoxPlaceholder"/>
                <Canvas Height="0" Margin="0,4,0,0">
                    <TextBlock Text="▲" Foreground="#CC3300" Canvas.Top="-5" Canvas.Left="15"/>
                    <Border Background="#CC3300" CornerRadius="4" Padding="10,6" Canvas.Top="7" MinWidth="200">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ⓧ" Margin="0,0,5,0" FontWeight="Bold" Foreground="#FFF" FontSize="20"/>
                            <TextBlock Text="{Binding [0].ErrorContent}" FontWeight="SemiBold" Foreground="#FFF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Canvas>
            </StackPanel>
        </ControlTemplate>
        <ControlTemplate x:Key="WarningTemplate">
            <StackPanel>
                <AdornedElementPlaceholder x:Name="TextBoxPlaceholder"/>
                <Canvas Height="0" Margin="0,4,0,0">
                    <TextBlock Text="▲" Foreground="#FFB000" Canvas.Top="-5" Canvas.Left="15"/>
                    <Border Background="#FFB000" CornerRadius="4" Padding="10,6" Canvas.Top="7" MinWidth="200">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="ⓘ" Margin="0,0,5,0" FontWeight="Bold" FontSize="20" Foreground="#FFF"/>
                            <TextBlock Text="{Binding [0].ErrorContent}" FontWeight="SemiBold" Foreground="#FFF" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Canvas>
            </StackPanel>
        </ControlTemplate>
        
        <Style TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11px"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="28,8"/>
               <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border x:Name="Border"
                                Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                <ContentPresenter/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Cursor" Value="Hand" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Cursor" Value="Arrow" />
                    <Setter Property="Opacity" Value="0.3" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="6,5"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFF"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="AlternationCount" Value="2"/>
            <Setter Property="AlternatingRowBackground" Value="#0A000000"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type DataGridCell}">
                        <Border Padding="5" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                            <ContentPresenter SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Padding" Value="6"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="Foreground" Value="#555"/>
        </Style>
        <Style TargetType="{x:Type GroupBox}">
            <Setter Property="BorderBrush" Value="#11000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="8,7,8,8"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style TargetType="TabControl">
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Padding" Value="7,4"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="FontSize" Value="12px"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#33000000"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="Background" Value="#FFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="MainBorder" 
                            Background="{TemplateBinding Background}" 
                            BorderBrush="{TemplateBinding BorderBrush}" 
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="2">
                            <ScrollViewer x:Name="PART_ContentHost" 
                                Margin="{TemplateBinding Padding}" 
                                Focusable="False" 
                                HorizontalScrollBarVisibility="Hidden" 
                                VerticalScrollBarVisibility="Hidden"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Validation.ErrorTemplate" Value="{x:Null}"/>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Validation.HasError" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                        <Condition Property="Tag" Value="0"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Validation.ErrorTemplate" Value="{StaticResource ErrorTemplate}"/>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Validation.HasError" Value="True"/>
                        <Condition Property="IsKeyboardFocusWithin" Value="True"/>
                        <Condition Property="Tag" Value="1"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Validation.ErrorTemplate" Value="{StaticResource WarningTemplate}"/>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Validation.HasError" Value="True"/>
                        <Condition Property="Tag" Value="0"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="#CC3300"/>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Validation.HasError" Value="True"/>
                        <Condition Property="Tag" Value="1"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="#FFCC00"/>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Validation.HasError" Value="False"/>
                        <Condition Property="IsMouseOver" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="#555555"/>
                </MultiTrigger>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="Validation.HasError" Value="False"/>
                        <Condition Property="IsFocused" Value="True"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="BorderBrush" Value="#0078D4"/>
                </MultiTrigger>

                <Trigger Property="IsEnabled" Value="True">
                    <Setter Property="Opacity" Value="1.0" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.3" />
                </Trigger>

                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <sys:Double x:Key="{x:Static SystemParameters.VerticalScrollBarWidthKey}">6</sys:Double>
        <sys:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarHeightKey}">6</sys:Double>

        <sys:Double x:Key="{x:Static SystemParameters.VerticalScrollBarButtonHeightKey}">0</sys:Double>
        <sys:Double x:Key="{x:Static SystemParameters.HorizontalScrollBarButtonWidthKey}">0</sys:Double>

        <Style x:Key="GreenButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#00CC00" />
            <Setter Property="BorderBrush" Value="#00CC00" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#00AA00" />
                    <Setter Property="BorderBrush" Value="#00AA00" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#007700" />
                    <Setter Property="BorderBrush" Value="#007700" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="BlueButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#0077FF" />
            <Setter Property="BorderBrush" Value="#0077FF" />
            <Setter Property="Foreground" Value="White" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0066DD" />
                    <Setter Property="BorderBrush" Value="#0066DD" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0055BB" />
                    <Setter Property="BorderBrush" Value="#0055BB" />
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <FontFamily x:Key="IconFont">/Font/#Font Awesome 7 Free Solid</FontFamily>

        <Style x:Key="Icon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="Foreground" Value="#777"/>
        </Style>
        <Style x:Key="Title" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#777"/>
        </Style>

        <Style x:Key="GroupTitlePanel" TargetType="DockPanel">
            <Setter Property="Margin" Value="5,0"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#0088EE"/>
        </Style>
        <Style x:Key="GroupTitleIcon" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="Foreground" Value="#0088EE"/>
        </Style>
        <Style x:Key="LabelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="12px"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="RoundLoader" TargetType="ProgressBar">
            <Setter Property="IsIndeterminate" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot" SnapsToDevicePixels="true">
                            <Ellipse Stroke="{TemplateBinding Background}" StrokeThickness="4" Opacity="1"/>
                            <Ellipse x:Name="AnimationElement" 
                                 Stroke="{TemplateBinding Foreground}" 
                                 StrokeThickness="4" 
                                 StrokeDashArray=".34 .34" 
                                 RenderTransformOrigin="0.5,0.5">
                                <Ellipse.RenderTransform>
                                    <RotateTransform x:Name="Rotate" Angle="0"/>
                                </Ellipse.RenderTransform>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsIndeterminate" Value="true">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard RepeatBehavior="Forever">
                                            <DoubleAnimation Storyboard.TargetName="AnimationElement"
                                                Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                From="0" To="360" Duration="0:0:2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>
            <Border       
                Background="#07000000"
                BorderBrush="#22000000"
                BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TabControl Margin="10,10,10,0" Padding="10,8,10,10">
                        <TabItem>
                            <TabItem.Header>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf07b;</TextBlock>
                                    <TextBlock Style="{StaticResource Title}">FOLDER</TextBlock>
                                </DockPanel>
                            </TabItem.Header>
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding FolderPreview}"
                                        Height="28" Width="28"
                                        Margin="0,0,5,0" 
                                        Stretch="UniformToFill"
                                        Visibility="{Binding FolderPreview, Converter={StaticResource ToVisibilityConverter}}"/>
                                    <TextBox Grid.Column="1" x:Name="FolderElement" 
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Center"
                                        Tag="0">
                                        <Binding Path="Folder" UpdateSourceTrigger="LostFocus">
                                            <Binding.ValidationRules>
                                                <local:FolderRule ValidatesOnTargetUpdated="True"/>
                                            </Binding.ValidationRules>
                                        </Binding>
                                    </TextBox>
                                    <Button Grid.Column="2" Content="Browse..." Click="OnBrowse" Margin="10,0,0,0" Style="{StaticResource BlueButton}"/>
                                </Grid>

                                <CheckBox Content="Include subfolders" 
                                    IsChecked="{Binding FolderSub, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                    Margin="0,10,0,0" 
                                    Checked="OnUpdated" 
                                    Unchecked="OnUpdated"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                    <TabControl Grid.Row="1" Margin="10">
                        <TabItem>
                            <TabItem.Header>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf15b;</TextBlock>
                                    <TextBlock Style="{StaticResource Title}">File</TextBlock>
                                </DockPanel>
                            </TabItem.Header>
                            <ScrollViewer 
                                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}"
                                HorizontalScrollBarVisibility="Disabled" 
                                Padding="10,8,10,10"
                                VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <GroupBox>
                                        <GroupBox.Header>
                                            <DockPanel Style="{StaticResource GroupTitlePanel}">
                                                <TextBlock Style="{StaticResource GroupTitle}">NAME</TextBlock>
                                            </DockPanel>
                                        </GroupBox.Header>
                                        <Grid Margin="0,0,0,-5">
                                            <Grid.RowDefinitions>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <Label Grid.Row="0">
                                                <StackPanel>
                                                    <TextBlock Style="{StaticResource LabelTitle}">
                                                        <Run>Format</Run> <Run FontStyle="Italic" Foreground="#55000000">{n} = number</Run>
                                                    </TextBlock>
                                                    <TextBox x:Name="FileNameFormatElement">
                                                        <Binding Path="FileNameFormat" UpdateSourceTrigger="LostFocus">
                                                            <Binding.ValidationRules>
                                                                <local:FileNameFormatRule ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="1">
                                                <StackPanel>
                                                    <TextBlock Text="Increment at" Style="{StaticResource LabelTitle}"/>
                                                    <TextBox Tag="0" x:Name="FileNameIncrementAtElement" TextChanged="OnUpdated">
                                                        <Binding Path="FileNameIncrementAt" UpdateSourceTrigger="PropertyChanged">
                                                            <Binding.ValidationRules>
                                                                <local:NumberRule ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="2">
                                                <StackPanel>
                                                    <TextBlock Text="Increment by" Style="{StaticResource LabelTitle}"/>
                                                    <TextBox Tag="0" x:Name="FileNameIncrementByElement" TextChanged="OnUpdated">
                                                        <Binding Path="FileNameIncrementBy" UpdateSourceTrigger="PropertyChanged">
                                                            <Binding.ValidationRules>
                                                                <local:NumberRule ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="3">
                                                <CheckBox Content="Increment by extension" 
                                                    IsChecked="{Binding FileNameIncrementByExtension, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                    Checked="OnUpdated" Unchecked="OnUpdated"/>
                                            </Label>
                                            <Label Grid.Row="4">
                                                <StackPanel>
                                                    <TextBlock Text="Number" Style="{StaticResource LabelTitle}"/>
                                                    <ComboBox SelectedIndex="{Binding FileNameNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        SelectionChanged="OnUpdated">
                                                        <ComboBoxItem Content="Binary"/>
                                                        <ComboBoxItem Content="Decimal"/>
                                                        <ComboBoxItem Content="Hexadecimal"/>
                                                        <ComboBoxItem Content="Letter (Lower)"/>
                                                        <ComboBoxItem Content="Letter (Upper)"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="5">
                                                <StackPanel>
                                                    <TextBlock Text="Number padding" Style="{StaticResource LabelTitle}"/>
                                                    <Slider Minimum="1" Maximum="10" Value="{Binding FileNameNumberPadding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TickPlacement="BottomRight" TickFrequency="1" IsSnapToTickEnabled="True" ValueChanged="OnUpdated"/>
                                                </StackPanel>
                                            </Label>
                                            <Label Grid.Row="6">
                                                <StackPanel>
                                                    <TextBlock Text="Number padding character" Style="{StaticResource LabelTitle}"/>
                                                    <TextBox x:Name="FileNameNumberPaddingCharacterElement" Tag="0" MaxLength="1" TextChanged="OnUpdated">
                                                        <Binding Path="FileNameNumberPaddingCharacter" UpdateSourceTrigger="PropertyChanged">
                                                            <Binding.ValidationRules>
                                                                <local:MinimumRule Minimum="1" ValidatesOnTargetUpdated="True"/>
                                                                <local:FileNameRule ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>
                                        </Grid>
                                    </GroupBox>
                                    <GroupBox>
                                        <GroupBox.Header>
                                            <DockPanel Style="{StaticResource GroupTitlePanel}">
                                                <TextBlock Style="{StaticResource GroupTitle}">EXTENSION</TextBlock>
                                            </DockPanel>
                                        </GroupBox.Header>
                                        <StackPanel>
                                            <Label>
                                                <StackPanel>
                                                    <DockPanel Margin="0,0,0,5">
                                                        <CheckBox Content="Override" IsChecked="{Binding FileExtensionOverride, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                                    </DockPanel>
                                                    <TextBox Tag="1" IsEnabled="{Binding FileExtensionOverride}" TextChanged="OnUpdated">
                                                        <Binding Path="FileExtensionOverrideNew" UpdateSourceTrigger="PropertyChanged">
                                                            <Binding.ValidationRules>
                                                                <local:FileRule ValidatesOnTargetUpdated="True"/>
                                                            </Binding.ValidationRules>
                                                        </Binding>
                                                    </TextBox>
                                                </StackPanel>
                                            </Label>

                                            <Label>
                                                <StackPanel>
                                                    <TextBlock Text="Casing" Style="{StaticResource LabelTitle}"/>
                                                    <ComboBox SelectedIndex="{Binding FileExtensionCasing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                        SelectionChanged="OnUpdated">
                                                        <ComboBoxItem Content="Original"/>
                                                        <ComboBoxItem Content="lowercase"/>
                                                        <ComboBoxItem Content="UPPERCASE"/>
                                                        <ComboBoxItem Content="Capitalized"/>
                                                    </ComboBox>
                                                </StackPanel>
                                            </Label>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem>
                            <TabItem.Header>
                                <DockPanel>
                                    <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf013;</TextBlock>
                                    <TextBlock Style="{StaticResource Title}">Options</TextBlock>
                                </DockPanel>
                            </TabItem.Header>
                            <StackPanel Margin="10,8,10,10">
                                <GroupBox>
                                    <GroupBox.Header>
                                        <DockPanel Style="{StaticResource GroupTitlePanel}">
                                            <TextBlock Style="{StaticResource GroupTitleIcon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf017;</TextBlock>
                                            <TextBlock Style="{StaticResource GroupTitle}">Delay</TextBlock>
                                        </DockPanel>
                                    </GroupBox.Header>
                                    <StackPanel>
                                        <Label>
                                            <StackPanel>
                                                <TextBlock Text="Renaming" Style="{StaticResource LabelTitle}"/>
                                                <TextBox Tag="0">
                                                    <Binding Path="DelayRename" UpdateSourceTrigger="PropertyChanged">
                                                        <Binding.ValidationRules>
                                                            <local:NumberRule ValidatesOnTargetUpdated="True"/>
                                                        </Binding.ValidationRules>
                                                    </Binding>
                                                </TextBox>
                                            </StackPanel>
                                        </Label>
                                        <Label>
                                            <StackPanel>
                                                <TextBlock Text="Updating" Style="{StaticResource LabelTitle}"/>
                                                <TextBox Tag="0">
                                                    <Binding Path="DelayUpdate" UpdateSourceTrigger="PropertyChanged">
                                                        <Binding.ValidationRules>
                                                            <local:NumberRule ValidatesOnTargetUpdated="True"/>
                                                        </Binding.ValidationRules>
                                                    </Binding>
                                                </TextBox>
                                            </StackPanel>
                                        </Label>
                                    </StackPanel>
                                </GroupBox>
                                <GroupBox>
                                    <GroupBox.Header>
                                        <DockPanel Style="{StaticResource GroupTitlePanel}">
                                            <TextBlock Style="{StaticResource GroupTitleIcon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf188;</TextBlock>
                                            <TextBlock Style="{StaticResource GroupTitle}">Log</TextBlock>
                                        </DockPanel>
                                    </GroupBox.Header>
                                    <StackPanel>
                                        <CheckBox Content="Enable" IsChecked="{Binding LogEnable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
            <GridSplitter Grid.Column="1" ResizeBehavior="PreviousAndNext" ResizeDirection="Columns" Background="Transparent" ShowsPreview="True" Width="10"/>
            <TabControl Grid.Column="2"
                Margin="0,10,10,10">
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf15b;</TextBlock>
                            <TextBlock Style="{StaticResource Title}" VerticalAlignment="Center">Files</TextBlock>
                            <Border Background="#0088EE" CornerRadius="3" Margin="5,0" Padding="5,3">
                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="#FFF" Text="{Binding FileCount}"/>
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <Grid Margin="-2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <DataGrid
                            AutoGenerateColumns="False"
                            BorderThickness="0"
                            HeadersVisibility="Column"
                            ItemsSource="{Binding Actions}"
                            SelectionMode="Single"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            CanUserReorderColumns="False"
                            CanUserResizeColumns="True"
                            CanUserResizeRows="False"
                            CanUserSortColumns="True">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Image Source="{Binding OldPath, Converter={StaticResource ThumbnailConverter}}"
                                                Height="20" Width="20"
                                                Stretch="UniformToFill"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Old" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding OldName}" ToolTip="{Binding OldPath}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="New" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                        <TextBlock Text="{Binding NewName}" ToolTip="{Binding NewPath}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Status" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Ellipse Width="8" Height="8" Fill="{Binding Status}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Folder" Binding="{Binding RelativeFolder}" Visibility="Collapsed"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Border Grid.Row="1" 
                            Background="#07000000" 
                            BorderBrush="#22000000" 
                            BorderThickness="1"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBooleanConverter}}" 
                            Margin="-3" 
                            Padding="5">
                            <DockPanel HorizontalAlignment="Right">
                                <CheckBox x:Name="AutoUpdateElement" Content="Auto update" IsChecked="True" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <Button Click="OnUpdate" IsEnabled="{Binding IsChecked, Converter={StaticResource InverseBooleanConverter}, ElementName=AutoUpdateElement}" Style="{StaticResource BlueButton}">
                                    <DockPanel>
                                        <TextBlock Text="&#xf021;"                            
                                            Foreground="#FFF"
                                            Margin="0,0,5,0" 
                                            RenderTransformOrigin="0.5,0.5"
                                            VerticalAlignment="Center">
                                            <TextBlock.RenderTransform>
                                                <RotateTransform Angle="0"/>
                                            </TextBlock.RenderTransform>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource Icon}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsUpdating}" Value="True">
                                                            <DataTrigger.EnterActions>
                                                                <BeginStoryboard x:Name="RotateAction">
                                                                    <Storyboard>
                                                                        <DoubleAnimation
                                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                            From="0"
                                                                            To="360"
                                                                            RepeatBehavior="Forever"
                                                                            Duration="0:0:2"/>
                                                                    </Storyboard>
                                                                </BeginStoryboard>
                                                            </DataTrigger.EnterActions>
                                                            <DataTrigger.ExitActions>
                                                                <StopStoryboard BeginStoryboardName="RotateAction"/>
                                                            </DataTrigger.ExitActions>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock>Update</TextBlock>
                                    </DockPanel>
                                </Button>
                            </DockPanel>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="IsEnabled" Value="True"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FolderElement}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameFormatElement}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameIncrementByElement}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameIncrementAtElement}" Value="True">
                                            <Setter Property="IsEnabled" Value="False"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </Grid>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource Icon}" Margin="0,0,5,0" VerticalAlignment="Center">&#xf188;</TextBlock>
                            <TextBlock Style="{StaticResource Title}" VerticalAlignment="Center">Log</TextBlock>
                            <Border Background="#0088EE" CornerRadius="3" Margin="5,0,0,0" Padding="5,3">
                                <TextBlock FontSize="10" FontWeight="Bold" Foreground="#FFF" Text="{Binding LogCount}"/>
                            </Border>
                        </StackPanel>
                    </TabItem.Header>
                    <DataGrid
                        AutoGenerateColumns="False"
                        BorderThickness="0"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        CanUserReorderColumns="False"
                        CanUserResizeColumns="True"
                        CanUserResizeRows="False"
                        CanUserSortColumns="True"
                        HeadersVisibility="Column"
                        ItemsSource="{Binding Log}" 
                        Margin="-2"
                        SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Message" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Message}"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>
            </TabControl>
        </Grid>
        <ProgressBar Grid.Row="1" 
            BorderBrush="#33000000"
            BorderThickness="0,1,0,0"
            Height="8" 
            IsIndeterminate="True"
            Visibility="{Binding IsBusy, Converter={StaticResource BooleanToVisibilityConverter}}"/>
        <Border Grid.Row="2" Background="#11000000" BorderThickness="0,1,0,0" BorderBrush="#33000000" Padding="5">
            <Button Click="OnRenamed">
                <Button.Content>
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock Text="&#xf021;"
                            Foreground="#FFF"
                            Margin="0,0,5,0" 
                            RenderTransformOrigin="0.5,0.5" 
                            VerticalAlignment="Center">
                            <TextBlock.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </TextBlock.RenderTransform>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource Icon}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="RotateAction">
                                                    <Storyboard>
                                                        <DoubleAnimation
                                                            Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                            From="0"
                                                            To="360"
                                                            RepeatBehavior="Forever"
                                                            Duration="0:0:3"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="RotateAction"/>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="Rename" VerticalAlignment="Center"/>
                        <Border Background="#33000000" Margin="5,0" Padding="5,2">
                            <TextBlock FontStyle="Italic" Text="{Binding FileCountText}" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Button.Content>
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource GreenButton}">
                        <Setter Property="IsEnabled" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FolderElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameFormatElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameIncrementByElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameIncrementAtElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding (Validation.HasError), ElementName=FileNameNumberPaddingCharacterElement}" Value="True">
                                <Setter Property="IsEnabled" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers> 
                    </Style>
                </Button.Style>
            </Button>
        </Border>
    </Grid>
</Window>